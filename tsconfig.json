{
  "compilerOptions": {
      "module": "Node16",
      "types": ["jest", "node"],
      "isolatedModules": true,
      "target": "ES2022",
      "lib": ["ES2023", "DOM"],
      "paths": {
          "@/*": ["./src/*"]
      },
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true,
  },
  "exclude": [
      "node_modules"
  ]
}